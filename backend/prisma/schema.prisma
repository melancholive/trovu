generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("buyer")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  artistProfile    ArtistProfile?
  buyerCommissions Commission[]   @relation("BuyerCommissions")
}

model ArtistProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])

  bio           String?
  country       String
  currency      String   @default("USD")
  portfolioUrls String[]

  acceptingCommissions Boolean @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pricingTiers  PricingTier[]
  commissions   Commission[]
}

model PricingTier {
  id              String   @id @default(uuid())
  artistProfileId String
  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id])

  name            String
  flexibility     String
  price           Int
  revisionRounds  Int      @default(0)
  description     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  commissions     Commission[]
}

model Commission {
  id              String   @id @default(uuid())

  buyerId         String
  buyer           User     @relation("BuyerCommissions", fields: [buyerId], references: [id])

  artistProfileId String
  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id])

  pricingTierId   String
  pricingTier     PricingTier   @relation(fields: [pricingTierId], references: [id])

  brief           String
  referenceUrls   String[]

  agreedPrice     Int
  revisionRounds  Int

  status          String   @default("pending")
  paymentStatus   String   @default("unpaid")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  milestones      Milestone[]
  revisionsUsed   Int      @default(0)
}

model Milestone {
  id            String   @id @default(uuid())
  commissionId  String
  commission    Commission @relation(fields: [commissionId], references: [id])

  stage         String
  imageUrl      String?
  status        String   @default("pending")
  feedback      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}